# 配置文件示例

# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# 模型配置
NLP_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
ESSAY_MODEL_NAME=hfl/chinese-bert-wwm

# 数据库配置（可选）
DATABASE_URL=postgresql://user:password@localhost:5432/homework_grading
REDIS_URL=redis://localhost:6379/0

# Celery 配置（可选）
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# 批改阈值配置
OBJECTIVE_TOLERANCE=0.9
SUBJECTIVE_MIN_CONFIDENCE=0.7
ESSAY_MIN_SCORE=0.6

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
